# =============================================================================
# E-Commerce Real-Time Data Platform — Environment (Local Portfolio Defaults)
# =============================================================================

# --- Kafka ---
KAFKA_BOOTSTRAP_SERVERS=kafka:29092
KAFKA_BOOTSTRAP_SERVERS_EXTERNAL=localhost:9092

# --- PostgreSQL (metrics + warehouse + CDC source) ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=ecommerce
POSTGRES_USER=ecommerce_user
POSTGRES_PASSWORD=ecommerce_pass
POSTGRES_METRICS_DB=ecommerce
POSTGRES_METRICS_SCHEMA=realtime
POSTGRES_WAREHOUSE_SCHEMA=warehouse

# --- Spark ---
SPARK_MASTER=spark://spark-master:7077
SPARK_APP_NAME=ecommerce-streaming
SPARK_CHECKPOINT_BASE=/data-lake/checkpoints
SPARK_TRIGGER_INTERVAL=30 seconds
SPARK_WATERMARK_DELAY=10 minutes

# --- Data Lake (local parquet — no AWS required) ---
DATA_LAKE_MODE=local
DATA_LAKE_ROOT=/data-lake

# --- Optional S3/MinIO (set DATA_LAKE_MODE=s3 and start --profile s3) ---
# DATA_LAKE_MODE=s3
# S3_DATA_LAKE_BUCKET=ecommerce-data-lake
# S3_ENDPOINT_URL=http://minio:9000
# AWS_ACCESS_KEY_ID=minioadmin
# AWS_SECRET_ACCESS_KEY=minioadmin

# --- Simulated cloud services (reference only) ---
GLUE_SIMULATED=true
REDSHIFT_SIMULATED=true
REDSHIFT_HOST=
REDSHIFT_IAM_ROLE=arn:aws:iam::000000000000:role/RedshiftCopyRole

# --- Producer (~15 events/sec ≈ 1.3M events/day) ---
PRODUCER_EVENTS_PER_SECOND=15

# --- Dashboard ---
DASHBOARD_REFRESH_SECONDS=5
METRICS_SOURCE=postgres

# --- Logging ---
LOG_LEVEL=INFO
